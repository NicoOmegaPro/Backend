generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                  Int                  @id @default(autoincrement())
  nombre              String
  email               String               @unique
  password            String
  descripcion         String?
  imagenPerfil        String?              // Ruta local
  esAdmin             Boolean              @default(false) // Admin global: acceso total. El resto de roles son por equipo.
  equipos             EquipoUsuario[]
  tareasAsignadas     Tarea[]              @relation("AsignadoA")
  comentarios         Comentario[]
  adjuntos            Adjunto[]
  notificaciones      Notificacion[]
  historialActividad  HistorialActividad[]
  proyectosLiderados  Proyecto[]           @relation("LiderProyecto")
}

model Equipo {
  id              Int              @id @default(autoincrement())
  nombre          String
  descripcion     String?
  imagen          String?          // Ruta local de la imagen/avatar del equipo
  usuarios        EquipoUsuario[]
  proyectos       Proyecto[]       // Proyectos de los que este equipo es el dueño/creador
  proyectosVinculados ProyectoEquipo[] // Proyectos en los que colabora (incluye los propios)
}

model EquipoUsuario {
  usuarioId Int
  equipoId  Int
  rol       String  @default("MIEMBRO")    // JEFE_EQUIPO | SUPERVISOR | MIEMBRO (único nivel de rol)
  estado    String  @default("ACEPTADO")   // PENDIENTE | ACEPTADO | RECHAZADO
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  equipo    Equipo  @relation(fields: [equipoId], references: [id], onDelete: Cascade)

  @@id([usuarioId, equipoId])
}

model Proyecto {
  id          Int       @id @default(autoincrement())
  nombre      String
  descripcion String?
  estado      String    @default("ACTIVO") // ACTIVO, COMPLETADO, ARCHIVADO
  equipoId    Int?      // Equipo dueño/creador: su jefe gestiona el proyecto
  equipo      Equipo?   @relation(fields: [equipoId], references: [id])
  equipos     ProyectoEquipo[] // Todos los equipos del proyecto (dueño + invitados)
  liderId     Int?
  lider       Usuario?  @relation("LiderProyecto", fields: [liderId], references: [id])
  tareas      Tarea[]
  sprints     Sprint[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
}

model ProyectoEquipo {
  proyectoId Int
  equipoId   Int
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  equipo     Equipo   @relation(fields: [equipoId], references: [id], onDelete: Cascade)

  @@id([proyectoId, equipoId])
}

model Sprint {
  id          Int       @id @default(autoincrement())
  nombre      String
  objetivo    String?   // Meta / goal del sprint
  estado      String    @default("PLANIFICADO") // PLANIFICADO | ACTIVO | COMPLETADO
  fechaInicio DateTime
  fechaFin    DateTime
  proyectoId  Int
  proyecto    Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  tareas      Tarea[]
}

model Tarea {
  id              Int          @id @default(autoincrement())
  titulo          String
  descripcion     String?
  estado          String       @default("PENDIENTE") // PENDIENTE, EN_PROGRESO, EN_REVISION, FINALIZADO
  prioridad       String       @default("MEDIA")     // BAJA, MEDIA, ALTA, URGENTE
  orden           Int          @default(0)           // posición dentro de su columna (drag & drop)
  fechaVencimiento DateTime?                         // due date
  proyectoId      Int
  proyecto        Proyecto     @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  sprintId        Int?
  sprint          Sprint?      @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  asignadoAId     Int?
  asignadoA       Usuario?     @relation("AsignadoA", fields: [asignadoAId], references: [id])
  subtareas       Subtarea[]
  comentarios     Comentario[]
  adjuntos        Adjunto[]
  etiquetas       TareaEtiqueta[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @default(now()) @updatedAt
}

model Subtarea {
  id          Int     @id @default(autoincrement())
  titulo      String
  completada  Boolean @default(false)
  tareaId     Int
  tarea       Tarea   @relation(fields: [tareaId], references: [id], onDelete: Cascade)
}

model Comentario {
  id        Int      @id @default(autoincrement())
  contenido String
  fecha     DateTime @default(now())
  tareaId   Int
  tarea     Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  autorId   Int
  autor     Usuario  @relation(fields: [autorId], references: [id])
}

model Adjunto {
  id        Int      @id @default(autoincrement())
  rutaLocal String   // Ruta donde se almacena el archivo en el servidor
  nombre    String
  fecha     DateTime @default(now())
  tareaId   Int
  tarea     Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  subidoPor Int
  usuario   Usuario  @relation(fields: [subidoPor], references: [id])
}

model Etiqueta {
  id     Int             @id @default(autoincrement())
  nombre String
  color  String
  tareas TareaEtiqueta[]
}

model TareaEtiqueta {
  tareaId    Int
  etiquetaId Int
  tarea      Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  etiqueta   Etiqueta @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)

  @@id([tareaId, etiquetaId])
}

model Notificacion {
  id        Int      @id @default(autoincrement())
  mensaje   String
  tipo      String   // EJ: NUEVA_TAREA, CAMBIO_ESTADO
  leida     Boolean  @default(false)
  fecha     DateTime @default(now())
  usuarioId Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
}

model HistorialActividad {
  id          Int      @id @default(autoincrement())
  entidadTipo String   // EJ: TAREA, PROYECTO
  entidadId   Int
  accion      String   // EJ: CREADO, ACTUALIZADO, ELIMINADO
  detalles    String?
  fecha       DateTime @default(now())
  usuarioId   Int
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
}
