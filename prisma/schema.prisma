generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rol {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique // Ej: ADMINISTRADOR, JEFE_PROYECTO, SUPERVISOR, TRABAJADOR
  descripcion String?
  usuarios    Usuario[]
}

model Usuario {
  id                  Int                  @id @default(autoincrement())
  nombre              String
  email               String               @unique
  password            String
  descripcion         String?
  imagenPerfil        String?              // Ruta local
  rolId               Int?                 // Opcional: solo lo usa el Administrador global. Los usuarios normales no tienen rol global.
  rol                 Rol?                 @relation(fields: [rolId], references: [id])
  equipos             EquipoUsuario[]
  proyectos           ProyectoUsuario[]
  tareasAsignadas     Tarea[]              @relation("AsignadoA")
  comentarios         Comentario[]
  adjuntos            Adjunto[]
  notificaciones      Notificacion[]
  historialActividad  HistorialActividad[]
  proyectosLiderados  Proyecto[]           @relation("LiderProyecto")
}

model Equipo {
  id          Int             @id @default(autoincrement())
  nombre      String
  descripcion String?
  usuarios    EquipoUsuario[]
  proyectos   Proyecto[]
}

model EquipoUsuario {
  usuarioId Int
  equipoId  Int
  rol       String  @default("MIEMBRO")    // JEFE_EQUIPO | MIEMBRO (el rango de proyecto se asigna por proyecto en ProyectoUsuario)
  estado    String  @default("ACEPTADO")   // PENDIENTE | ACEPTADO | RECHAZADO
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  equipo    Equipo  @relation(fields: [equipoId], references: [id], onDelete: Cascade)

  @@id([usuarioId, equipoId])
}

model Proyecto {
  id          Int       @id @default(autoincrement())
  nombre      String
  descripcion String?
  estado      String    @default("ACTIVO") // ACTIVO, COMPLETADO, ARCHIVADO
  equipoId    Int?
  equipo      Equipo?   @relation(fields: [equipoId], references: [id])
  liderId     Int?
  lider       Usuario?  @relation("LiderProyecto", fields: [liderId], references: [id])
  miembros    ProyectoUsuario[]
  tareas      Tarea[]
  sprints     Sprint[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
}

// Rol específico de cada miembro dentro de un proyecto concreto.
model ProyectoUsuario {
  proyectoId Int
  usuarioId  Int
  rol        String   @default("TRABAJADOR") // JEFE_PROYECTO | SUPERVISOR | TRABAJADOR
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([proyectoId, usuarioId])
}

model Sprint {
  id          Int       @id @default(autoincrement())
  nombre      String
  objetivo    String?   // Meta / goal del sprint
  estado      String    @default("PLANIFICADO") // PLANIFICADO | ACTIVO | COMPLETADO
  fechaInicio DateTime
  fechaFin    DateTime
  proyectoId  Int
  proyecto    Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  tareas      Tarea[]
}

model Tarea {
  id              Int          @id @default(autoincrement())
  titulo          String
  descripcion     String?
  estado          String       @default("PENDIENTE") // PENDIENTE, EN_PROGRESO, EN_REVISION, FINALIZADO
  prioridad       String       @default("MEDIA")     // BAJA, MEDIA, ALTA, URGENTE
  orden           Int          @default(0)           // posición dentro de su columna (drag & drop)
  fechaVencimiento DateTime?                         // due date
  proyectoId      Int
  proyecto        Proyecto     @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  sprintId        Int?
  sprint          Sprint?      @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  asignadoAId     Int?
  asignadoA       Usuario?     @relation("AsignadoA", fields: [asignadoAId], references: [id])
  subtareas       Subtarea[]
  comentarios     Comentario[]
  adjuntos        Adjunto[]
  etiquetas       TareaEtiqueta[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @default(now()) @updatedAt
}

model Subtarea {
  id          Int     @id @default(autoincrement())
  titulo      String
  completada  Boolean @default(false)
  tareaId     Int
  tarea       Tarea   @relation(fields: [tareaId], references: [id], onDelete: Cascade)
}

model Comentario {
  id        Int      @id @default(autoincrement())
  contenido String
  fecha     DateTime @default(now())
  tareaId   Int
  tarea     Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  autorId   Int
  autor     Usuario  @relation(fields: [autorId], references: [id])
}

model Adjunto {
  id        Int      @id @default(autoincrement())
  rutaLocal String   // Ruta donde se almacena el archivo en el servidor
  nombre    String
  fecha     DateTime @default(now())
  tareaId   Int
  tarea     Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  subidoPor Int
  usuario   Usuario  @relation(fields: [subidoPor], references: [id])
}

model Etiqueta {
  id     Int             @id @default(autoincrement())
  nombre String
  color  String
  tareas TareaEtiqueta[]
}

model TareaEtiqueta {
  tareaId    Int
  etiquetaId Int
  tarea      Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  etiqueta   Etiqueta @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)

  @@id([tareaId, etiquetaId])
}

model Notificacion {
  id        Int      @id @default(autoincrement())
  mensaje   String
  tipo      String   // EJ: NUEVA_TAREA, CAMBIO_ESTADO
  leida     Boolean  @default(false)
  fecha     DateTime @default(now())
  usuarioId Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
}

model HistorialActividad {
  id          Int      @id @default(autoincrement())
  entidadTipo String   // EJ: TAREA, PROYECTO
  entidadId   Int
  accion      String   // EJ: CREADO, ACTUALIZADO, ELIMINADO
  detalles    String?
  fecha       DateTime @default(now())
  usuarioId   Int
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
}
