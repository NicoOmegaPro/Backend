<%- include('_header') %>
<div class="ph">
  <span class="ph-t"><%= title %></span>
  <a href="/admin/equipos" class="btn btn-g"><i class="bi bi-arrow-left"></i>Volver</a>
</div>
<div class="fc">
  <form action="<%= equipo ? '/admin/equipos/' + equipo.id : '/admin/equipos' %>" method="POST">
    <div class="f">
      <label>Nombre</label>
      <input type="text" name="nombre" value="<%= equipo ? equipo.nombre : '' %>" required>
    </div>
    <div class="f">
      <label>Descripción</label>
      <textarea name="descripcion" rows="2"><%= equipo ? (equipo.descripcion || '') : '' %></textarea>
    </div>
    <div class="f">
      <label>Miembros</label>
      <div style="max-height:220px;overflow-y:auto;border:1px solid #ddd;border-radius:6px;padding:8px;display:flex;flex-direction:column;gap:6px;">
        <% usuarios.forEach(u => { %>
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:normal;">
            <input type="checkbox" name="miembros" value="<%= u.id %>" <%= miembrosIds.includes(u.id) ? 'checked' : '' %>>
            <%= u.nombre %> <span style="color:#888;font-size:0.85em;">(<%= u.email %>)</span>
          </label>
        <% }) %>
      </div>
    </div>
    <div class="fa">
      <button type="submit" class="btn btn-p"><i class="bi bi-floppy"></i>Guardar</button>
    </div>
  </form>
</div>
<%- include('_footer') %>
