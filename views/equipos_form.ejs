<%- include('_header') %>
<div class="ph">
  <span class="ph-t"><%= title %></span>
  <a href="/admin/equipos" class="btn btn-g"><i class="bi bi-arrow-left"></i>Volver</a>
</div>
<div class="fc" style="max-width:640px;">
  <form action="<%= equipo ? '/admin/equipos/' + equipo.id : '/admin/equipos' %>" method="POST">
    <div class="f-row">
      <div class="f">
        <label>Nombre</label>
        <input type="text" name="nombre" value="<%= equipo ? equipo.nombre : '' %>" required>
      </div>
      <div class="f">
        <label>Imagen (URL o ruta)</label>
        <input type="text" name="imagen" value="<%= equipo && equipo.imagen ? equipo.imagen : '' %>" placeholder="https://… o /uploads/…">
      </div>
    </div>
    <div class="f">
      <label>Descripción</label>
      <textarea name="descripcion" rows="2"><%= equipo ? (equipo.descripcion || '') : '' %></textarea>
    </div>
    <div class="f">
      <label>Miembros, roles y estado</label>
      <div style="max-height:300px;overflow-y:auto;border:1px solid var(--border);border-radius:9px;padding:8px;display:flex;flex-direction:column;gap:4px;background:var(--bg-secondary);">
        <% usuarios.forEach(u => { const m = miembros[u.id]; %>
          <div style="display:flex;align-items:center;gap:8px;padding:5px 6px;border-radius:7px;">
            <input type="checkbox" name="miembros" value="<%= u.id %>" <%= m ? 'checked' : '' %> style="width:15px;height:15px;accent-color:var(--accent);">
            <div style="flex:1;min-width:0;">
              <div style="font-size:12.5px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= u.nombre %></div>
              <div style="font-size:11px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= u.email %></div>
            </div>
            <select name="rol_<%= u.id %>" style="width:130px;flex-shrink:0;padding:5px 8px;font-size:12px;">
              <% ['JEFE_EQUIPO','SUPERVISOR','MIEMBRO'].forEach(r => { %>
                <option value="<%= r %>" <%= (m && m.rol === r) || (!m && r === 'MIEMBRO') ? 'selected' : '' %>><%= r %></option>
              <% }) %>
            </select>
            <select name="estado_<%= u.id %>" style="width:120px;flex-shrink:0;padding:5px 8px;font-size:12px;">
              <% ['ACEPTADO','PENDIENTE','RECHAZADO'].forEach(e => { %>
                <option value="<%= e %>" <%= (m && m.estado === e) || (!m && e === 'ACEPTADO') ? 'selected' : '' %>><%= e %></option>
              <% }) %>
            </select>
          </div>
        <% }) %>
      </div>
      <p style="font-size:11px;color:var(--muted);margin-top:6px;">Marca el usuario para incluirlo y elige su rol y estado. El rol/estado solo aplica a los marcados.</p>
    </div>
    <div class="fa">
      <button type="submit" class="btn btn-p"><i class="bi bi-floppy"></i>Guardar</button>
    </div>
  </form>
</div>
<%- include('_footer') %>
