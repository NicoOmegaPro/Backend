<%- include('_header') %>
<div class="ph">
  <span class="ph-t"><%= title %></span>
  <a href="/admin/tasks" class="btn btn-g"><i class="bi bi-arrow-left"></i>Volver</a>
</div>
<div class="fc">
  <form action="<%= task ? '/admin/tasks/' + task.id : '/admin/tasks' %>" method="POST">
    <div class="f">
      <label>Título</label>
      <input type="text" name="titulo" value="<%= task ? task.titulo : '' %>" required>
    </div>
    <div class="f">
      <label>Descripción</label>
      <textarea name="descripcion" rows="2"><%= task ? (task.descripcion || '') : '' %></textarea>
    </div>
    <div class="f-row">
      <div class="f">
        <label>Estado</label>
        <select name="estado">
          <% ['PENDIENTE','EN_PROGRESO','EN_REVISION','FINALIZADO'].forEach(e => { %>
          <option value="<%= e %>" <%= task && task.estado === e ? 'selected' : '' %>><%= e %></option>
          <% }) %>
        </select>
      </div>
      <div class="f">
        <label>Prioridad</label>
        <select name="prioridad">
          <% ['BAJA','MEDIA','ALTA','URGENTE'].forEach(p => { %>
          <option value="<%= p %>" <%= task && task.prioridad === p ? 'selected' : '' %>><%= p %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="f">
      <label>Proyecto</label>
      <select name="proyectoId" required>
        <option value="">-- Selecciona un proyecto --</option>
        <% projects.forEach(p => { %>
        <option value="<%= p.id %>" <%= task && task.proyectoId === p.id ? 'selected' : '' %>><%= p.nombre %></option>
        <% }) %>
      </select>
    </div>
    <div class="f">
      <label>Asignado a</label>
      <select name="asignadoAId">
        <option value="">-- Sin asignar --</option>
        <% users.forEach(u => { %>
        <option value="<%= u.id %>" <%= task && task.asignadoAId === u.id ? 'selected' : '' %>><%= u.nombre %></option>
        <% }) %>
      </select>
    </div>
    <div class="f">
      <label>Sprint</label>
      <select name="sprintId">
        <option value="">-- Sin sprint --</option>
        <% sprints.forEach(s => { %>
        <option value="<%= s.id %>" <%= task && task.sprintId === s.id ? 'selected' : '' %>><%= s.nombre %></option>
        <% }) %>
      </select>
    </div>
    <div class="fa">
      <button type="submit" class="btn btn-p"><i class="bi bi-floppy"></i>Guardar</button>
    </div>
  </form>
</div>
<%- include('_footer') %>
