<%- include('_header') %>
<div class="ph">
  <span class="ph-t">Proyectos</span>
  <a href="/admin/projects/create" class="btn btn-p"><i class="bi bi-plus-lg"></i>Nuevo proyecto</a>
</div>
<div class="dc">
  <div class="tw">
    <table class="dt">
      <thead>
        <tr><th>ID</th><th>Nombre</th><th>Estado</th><th>Equipo</th><th>Líder</th><th></th></tr>
      </thead>
      <tbody>
        <% const estadoCls = { ACTIVO:'tg-green', COMPLETADO:'tg-blue', ARCHIVADO:'tg-slate' }; %>
        <% projects.forEach(p => { %>
        <tr>
          <td class="ci"><%= p.id %></td>
          <td><strong><%= p.nombre %></strong></td>
          <td><span class="tg <%= estadoCls[p.estado] || 'tg-slate' %>"><%= p.estado %></span></td>
          <td class="cm"><%= p.equipo?.nombre || '-' %></td>
          <td class="cm"><%= p.lider?.nombre || '-' %></td>
          <td class="ca">
            <a href="/admin/projects/<%= p.id %>/edit" class="ib ib-e"><i class="bi bi-pencil"></i></a>
            <form action="/admin/projects/<%= p.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('¿Eliminar proyecto?')">
              <button class="ib ib-d"><i class="bi bi-trash"></i></button>
            </form>
          </td>
        </tr>
        <% }) %>
        <% if (!projects.length) { %><tr class="erow"><td colspan="6">Sin registros</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>
<%- include('_footer') %>
