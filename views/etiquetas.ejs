<%- include('_header') %>
<div class="ph">
  <span class="ph-t">Etiquetas</span>
  <a href="/admin/etiquetas/create" class="btn btn-p"><i class="bi bi-plus-lg"></i>Nueva etiqueta</a>
</div>
<%- include('_search') %>
<div class="dc">
  <div class="tw">
    <table class="dt">
      <thead>
        <tr><th>ID</th><th>Nombre</th><th>Color</th><th>Tareas</th><th></th></tr>
      </thead>
      <tbody>
        <% etiquetas.forEach(e => { %>
        <tr>
          <td class="ci"><%= e.id %></td>
          <td><strong><%= e.nombre %></strong></td>
          <td>
            <span style="display:inline-flex;align-items:center;gap:7px">
              <span style="width:13px;height:13px;border-radius:3px;background:<%= e.color %>;display:inline-block;flex-shrink:0"></span>
              <code style="font-size:11.5px;color:#64748b"><%= e.color %></code>
            </span>
          </td>
          <td><span class="tg tg-slate"><%= e._count.tareas %></span></td>
          <td class="ca">
            <a href="/admin/etiquetas/<%= e.id %>/edit" class="ib ib-e"><i class="bi bi-pencil"></i></a>
            <form action="/admin/etiquetas/<%= e.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('¿Eliminar etiqueta?')">
              <button class="ib ib-d"><i class="bi bi-trash"></i></button>
            </form>
          </td>
        </tr>
        <% }) %>
        <% if (!etiquetas.length) { %><tr class="erow"><td colspan="5">Sin registros</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>
<%- include('_pagination') %>
<%- include('_footer') %>
