<%- include('_header') %>
<div class="ph">
  <span class="ph-t"><%= title %></span>
  <a href="/admin/users" class="btn btn-g"><i class="bi bi-arrow-left"></i>Volver</a>
</div>
<div class="fc">
  <form action="<%= user ? '/admin/users/' + user.id : '/admin/users' %>" method="POST">
    <div class="f">
      <label>Nombre</label>
      <input type="text" name="nombre" value="<%= user ? user.nombre : '' %>" required>
    </div>
    <div class="f">
      <label>Email</label>
      <input type="email" name="email" value="<%= user ? user.email : '' %>" required>
    </div>
    <% if (!user) { %>
    <div class="f">
      <label>Contraseña</label>
      <input type="password" name="password" required>
    </div>
    <% } %>
    <div class="f">
      <label>Descripción</label>
      <textarea name="descripcion" rows="2"><%= user ? (user.descripcion || '') : '' %></textarea>
    </div>
    <div class="f">
      <label>Rol</label>
      <select name="rolId" required>
        <option value="">-- Selecciona un rol --</option>
        <% roles.forEach(r => { %>
        <option value="<%= r.id %>" <%= user && user.rolId === r.id ? 'selected' : '' %>><%= r.nombre %></option>
        <% }) %>
      </select>
    </div>
    <div class="fa">
      <button type="submit" class="btn btn-p"><i class="bi bi-floppy"></i>Guardar</button>
    </div>
  </form>
</div>
<%- include('_footer') %>
