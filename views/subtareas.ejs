<%- include('_header') %>
<div class="ph">
  <span class="ph-t">Subtareas</span>
  <a href="/admin/subtareas/create" class="btn btn-p"><i class="bi bi-plus-lg"></i>Nueva subtarea</a>
</div>
<div class="dc">
  <div class="tw">
    <table class="dt">
      <thead>
        <tr><th>ID</th><th>Título</th><th>Tarea</th><th>Estado</th><th></th></tr>
      </thead>
      <tbody>
        <% subtareas.forEach(s => { %>
        <tr>
          <td class="ci"><%= s.id %></td>
          <td><strong><%= s.titulo %></strong></td>
          <td class="cm"><%= s.tarea?.titulo || '-' %></td>
          <td><span class="tg <%= s.completada ? 'tg-green' : 'tg-slate' %>"><%= s.completada ? 'Completada' : 'Pendiente' %></span></td>
          <td class="ca">
            <a href="/admin/subtareas/<%= s.id %>/edit" class="ib ib-e"><i class="bi bi-pencil"></i></a>
            <form action="/admin/subtareas/<%= s.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('¿Eliminar subtarea?')">
              <button class="ib ib-d"><i class="bi bi-trash"></i></button>
            </form>
          </td>
        </tr>
        <% }) %>
        <% if (!subtareas.length) { %><tr class="erow"><td colspan="5">Sin registros</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>
<%- include('_footer') %>
