<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Noir Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:            #09070E;
      --bg-elev:       #0D0B14;
      --bg-secondary:  #181522;
      --card:          #131019;
      --card-hover:    #1B1726;
      --border:        #262130;
      --border-strong: #322C3F;
      --text:          #ECECEE;
      --muted:         #8B8B94;
      --faint:         #55555E;
      --accent:        #6E76F1;
      --accent-h:      #8A90F7;
      --accent-soft:   rgba(110,118,241,0.14);
      --success:       #3FB950;
      --warning:       #E0A82E;
      --danger:        #F0556B;
      --sb-bg:         #0D0B14;
      --sb-txt:        #8B8B94;
      --sb-w:          218px;
      --tb-h:          56px;
      --r:             12px;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 13.5px;
      line-height: 1.55;
      letter-spacing: -0.011em;
      -webkit-font-smoothing: antialiased;
    }

    /* Resplandor ambiental violeta (como el front) */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: -1; pointer-events: none;
      background:
        radial-gradient(38% 34% at 16% 8%, rgba(124,58,237,0.16), transparent 70%),
        radial-gradient(40% 36% at 88% 92%, rgba(110,118,241,0.14), transparent 72%);
    }

    /* ─── LAYOUT ─── */
    .shell { display: flex; height: 100vh; overflow: hidden; }

    /* ─── SIDEBAR ─── */
    .sb {
      width: var(--sb-w);
      background: color-mix(in srgb, var(--bg-elev) 80%, transparent);
      backdrop-filter: blur(12px);
      border-right: 1px solid var(--border);
      display: flex; flex-direction: column; flex-shrink: 0;
      overflow-y: auto; scrollbar-width: none;
    }
    .sb::-webkit-scrollbar { display: none; }

    .sb-brand {
      display: flex; align-items: center; gap: 10px;
      padding: 16px 16px;
      color: var(--text); font-size: 16px; font-weight: 700;
      letter-spacing: -0.02em;
      border-bottom: 1px solid var(--border);
    }
    .sb-brand img { height: 26px; width: auto; object-fit: contain; filter: drop-shadow(0 4px 14px rgba(110,118,241,.4)); }

    .sb-sec { padding: 14px 0 2px; }
    .sb-lbl {
      font-size: 10px; font-weight: 600; color: var(--faint);
      letter-spacing: 1.4px; text-transform: uppercase; padding: 0 16px 6px;
    }
    .sb-a {
      display: flex; align-items: center; gap: 10px;
      margin: 1px 8px; padding: 8px 10px;
      color: var(--sb-txt); font-size: 13px; font-weight: 500;
      text-decoration: none; border-radius: 9px;
      transition: color .14s, background .14s;
    }
    .sb-a i { font-size: 14px; width: 16px; flex-shrink: 0; text-align: center; }
    .sb-a:hover { color: var(--text); background: var(--bg-secondary); }
    .sb-a.on { color: #fff; background: var(--accent-soft); }
    .sb-a.on i { color: var(--accent-h); }

    /* ─── MAIN ─── */
    .mn { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }

    /* ─── TOPBAR ─── */
    .tb {
      height: var(--tb-h);
      background: color-mix(in srgb, var(--bg-elev) 80%, transparent);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; padding: 0 24px; flex-shrink: 0;
    }
    .tb-title { font-size: 15px; font-weight: 600; color: var(--text); }
    .tb-badge {
      margin-left: auto; display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 11px; border-radius: 20px;
      background: rgba(63,185,80,.14); color: var(--success);
      font-size: 11.5px; font-weight: 500;
    }
    .tb-badge i { font-size: 7px; }

    /* ─── PAGE BODY ─── */
    .pg { flex: 1; overflow-y: auto; padding: 24px; }

    /* ─── PAGE HEADER ─── */
    .ph { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .ph-t { font-size: 16px; font-weight: 700; letter-spacing: -0.01em; }

    /* ─── BUTTONS ─── */
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 8px 15px; font-size: 13px; font-weight: 600;
      border-radius: 9px; border: 1px solid transparent; cursor: pointer;
      text-decoration: none; line-height: 1; font-family: inherit;
      transition: background .14s, border-color .14s, color .14s, transform .08s;
    }
    .btn:active { transform: translateY(1px); }
    .btn i { font-size: 13px; }
    .btn-p { background: var(--accent); color: #fff; }
    .btn-p:hover { background: var(--accent-h); color: #fff; }
    .btn-g { background: var(--bg-secondary); color: var(--text); border-color: var(--border); }
    .btn-g:hover { background: var(--card-hover); border-color: var(--border-strong); }

    /* ─── ICON BUTTONS ─── */
    .ib {
      display: inline-flex; align-items: center; justify-content: center;
      width: 30px; height: 30px; border-radius: 8px; border: 1px solid;
      cursor: pointer; text-decoration: none; font-size: 13px;
      transition: background .14s; padding: 0;
    }
    .ib-e { background: var(--accent-soft); color: var(--accent-h); border-color: transparent; }
    .ib-e:hover { background: rgba(110,118,241,.24); }
    .ib-d { background: rgba(240,85,107,.12); color: var(--danger); border-color: transparent; }
    .ib-d:hover { background: rgba(240,85,107,.22); }

    /* ─── DATA CARD ─── */
    .dc { background: var(--card); border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; }
    .tw { overflow-x: auto; }

    /* ─── TABLE ─── */
    .dt { width: 100%; border-collapse: collapse; font-size: 13px; }
    .dt thead th {
      background: var(--bg-secondary); color: var(--muted);
      font-size: 10.5px; font-weight: 600; text-transform: uppercase;
      letter-spacing: .6px; padding: 11px 14px;
      border-bottom: 1px solid var(--border); white-space: nowrap; text-align: center;
    }
    .dt thead th:nth-child(2) { text-align: left; }
    .dt tbody td { padding: 11px 14px; border-bottom: 1px solid var(--border); vertical-align: middle; color: var(--text); }
    .dt tbody tr:last-child td { border-bottom: none; }
    .dt tbody tr:hover td { background: var(--card-hover); }
    .dt tbody td:has(.tg) { text-align: center; }
    .ci { font-family: 'Courier New', monospace; font-size: 12.5px; color: var(--faint); text-align: center; }
    .cm { font-size: 12.5px; color: var(--muted); }
    .cd { font-size: 12.5px; color: var(--muted); text-align: center; }
    .ca { text-align: right !important; white-space: nowrap; }
    .ca > * + * { margin-left: 4px; }
    .erow td { text-align: center; color: var(--muted); padding: 40px 0; font-size: 13px; }

    /* ─── TAGS ─── */
    .tg { display: inline-block; padding: 3px 9px; border-radius: 6px; font-size: 11.5px; font-weight: 600; white-space: nowrap; }
    .tg-blue   { background: var(--accent-soft);          color: var(--accent-h); }
    .tg-green  { background: rgba(63,185,80,.15);         color: #4ED164; }
    .tg-red    { background: rgba(240,85,107,.14);        color: var(--danger); }
    .tg-yellow { background: rgba(224,168,46,.14);        color: var(--warning); }
    .tg-orange { background: rgba(251,146,60,.14);        color: #FB923C; }
    .tg-purple { background: rgba(167,139,250,.15);       color: #A78BFA; }
    .tg-slate  { background: rgba(139,139,148,.14);       color: #B6B6BF; }
    .tg-teal   { background: rgba(45,212,191,.14);        color: #2DD4BF; }
    .tg-sky    { background: rgba(56,189,248,.14);        color: #38BDF8; }

    /* ─── FORM ─── */
    .fc { background: var(--card); border: 1px solid var(--border); border-radius: var(--r); padding: 24px; max-width: 520px; }
    .f { margin-bottom: 16px; }
    .f > label {
      display: block; font-size: 11px; font-weight: 600; color: var(--muted);
      margin-bottom: 6px; text-transform: uppercase; letter-spacing: .5px;
    }
    .f input:not([type=checkbox]):not([type=color]),
    .f select,
    .f textarea {
      width: 100%; padding: 9px 12px; font-size: 13px;
      border: 1px solid var(--border); border-radius: 9px;
      color: var(--text); background: var(--bg-secondary); outline: none;
      font-family: inherit; color-scheme: dark;
      transition: border-color .15s, box-shadow .15s;
    }
    .f input:not([type=checkbox]):not([type=color]):focus,
    .f select:focus,
    .f textarea:focus {
      border-color: var(--accent); box-shadow: 0 0 0 3px rgba(110,118,241,.2);
    }
    .f input::placeholder, .f textarea::placeholder { color: var(--faint); }
    .f input[type=color] {
      padding: 2px 4px; height: 38px; width: 64px;
      border: 1px solid var(--border); border-radius: 9px; cursor: pointer; background: var(--bg-secondary);
    }
    .f-row { display: flex; gap: 12px; }
    .f-row .f { flex: 1; }
    .f-check { display: flex; align-items: center; gap: 9px; margin-bottom: 16px; }
    .f-check input[type=checkbox] { width: 16px; height: 16px; cursor: pointer; accent-color: var(--accent); }
    .f-check label { font-size: 13px; font-weight: 500; cursor: pointer; color: var(--text); }
    .fa { display: flex; gap: 10px; margin-top: 20px; }

    /* ─── PAGINATION ─── */
    .pgn { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; margin-top: 16px; }
    .pgn-info { font-size: 12px; color: var(--muted); }
    .pgn-list { display: inline-flex; align-items: center; gap: 5px; }
    .pgn-a {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 32px; height: 32px; padding: 0 9px; border-radius: 8px;
      border: 1px solid var(--border); background: var(--bg-secondary);
      color: var(--muted); font-size: 12.5px; font-weight: 500; text-decoration: none;
      transition: background .12s, color .12s, border-color .12s;
    }
    .pgn-a:hover { background: var(--card-hover); color: var(--text); }
    .pgn-a.on { background: var(--accent); border-color: var(--accent); color: #fff; }
    .pgn-a.dis { opacity: .4; pointer-events: none; }
    .pgn-gap { padding: 0 4px; color: var(--muted); }
  </style>
</head>
<body>
<div class="shell">
  <aside class="sb">
    <div class="sb-brand"><img src="/logo.png" alt="Noir">Noir</div>
    <nav>
      <div class="sb-sec">
        <div class="sb-lbl">Gestión</div>
        <a href="/admin/users" class="sb-a <%= active==='users' ? 'on':'' %>"><i class="bi bi-people"></i>Usuarios</a>
      </div>
      <div class="sb-sec">
        <div class="sb-lbl">Trabajo</div>
        <a href="/admin/projects"  class="sb-a <%= active==='projects'  ? 'on':'' %>"><i class="bi bi-folder2"></i>Proyectos</a>
        <a href="/admin/equipos"   class="sb-a <%= active==='equipos'   ? 'on':'' %>"><i class="bi bi-diagram-3"></i>Equipos</a>
        <a href="/admin/sprints"   class="sb-a <%= active==='sprints'   ? 'on':'' %>"><i class="bi bi-lightning-charge"></i>Sprints</a>
        <a href="/admin/tasks"     class="sb-a <%= active==='tasks'     ? 'on':'' %>"><i class="bi bi-check2-square"></i>Tareas</a>
        <a href="/admin/subtareas" class="sb-a <%= active==='subtareas' ? 'on':'' %>"><i class="bi bi-list-task"></i>Subtareas</a>
      </div>
      <div class="sb-sec">
        <div class="sb-lbl">Contenido</div>
        <a href="/admin/etiquetas"   class="sb-a <%= active==='etiquetas'   ? 'on':'' %>"><i class="bi bi-tag"></i>Etiquetas</a>
        <a href="/admin/comentarios" class="sb-a <%= active==='comentarios' ? 'on':'' %>"><i class="bi bi-chat-left-text"></i>Comentarios</a>
        <a href="/admin/adjuntos"    class="sb-a <%= active==='adjuntos'    ? 'on':'' %>"><i class="bi bi-paperclip"></i>Adjuntos</a>
      </div>
      <div class="sb-sec">
        <div class="sb-lbl">Sistema</div>
        <a href="/admin/notificaciones" class="sb-a <%= active==='notificaciones' ? 'on':'' %>"><i class="bi bi-bell"></i>Notificaciones</a>
        <a href="/admin/historial"      class="sb-a <%= active==='historial'      ? 'on':'' %>"><i class="bi bi-clock-history"></i>Historial</a>
      </div>
    </nav>
  </aside>
  <div class="mn">
    <header class="tb">
      <span class="tb-title"><%= title %></span>
      <span class="tb-badge"><i class="bi bi-circle-fill"></i>En línea</span>
    </header>
    <div class="pg">
